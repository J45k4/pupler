{
	"name": "pupler",
	"private": true,
	"type": "module",
	"scripts": {
		"cli": "bun ./cli/cli.ts",
		"dev": "bun --watch src/main.ts",
		"postinstall": "bun run prisma:generate",
		"prisma:db:push": "bunx --bun prisma db push --schema prisma/schema.prisma",
		"prisma:generate": "bunx --bun prisma generate",
		"prisma:migrate:deploy": "bunx --bun prisma migrate deploy --schema prisma/schema.prisma",
		"prisma:migrate:dev": "bunx --bun prisma migrate dev --schema prisma/schema.prisma",
		"start": "bun src/main.ts",
		"test": "bun test",
		"test:cli": "bun test test/cli.test.ts",
		"test:e2e": "bun test test/e2e.test.ts"
	},
	"module": "index.ts",
	"devDependencies": {
		"@types/bun": "latest",
		"prisma": "^7.7.0"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@libsql/client": "^0.17.2",
		"@prisma/adapter-libsql": "^7.7.0",
		"@prisma/client": "^7.7.0"
	}
}
